{
  "name": "superpowers",
  "version": 1,
  "displayName": "Superpowers Method Policy",
  "defaultEnabled": true,
  "defaultEnforcement": "hard",
  "description": "Default SuperMaestro execution policy. It requires Superpowers skills for planning, coding, review, verification, and final branch handling while keeping those requirements outside the core workflow state machine.",
  "requirements": {
    "gate.plan.approve": [
      {
        "skill": "superpowers:writing-plans",
        "evidence": "used",
        "enforcement": "hard"
      }
    ],
    "action.code": [
      {
        "skill": "superpowers:test-driven-development",
        "evidence": "used-or-skipped-with-reason",
        "allowSkipWithReason": true,
        "enforcement": "hard"
      },
      {
        "skill": "superpowers:subagent-driven-development",
        "when": {
          "execution.subagents": true
        },
        "evidence": "used",
        "enforcement": "hard"
      },
      {
        "skill": "superpowers:executing-plans",
        "when": {
          "execution.subagents": false
        },
        "evidence": "used",
        "enforcement": "hard"
      }
    ],
    "action.dispatch-subagent": [
      {
        "skill": "superpowers:subagent-driven-development",
        "evidence": "used",
        "enforcement": "hard"
      }
    ],
    "gate.review.request": [
      {
        "skill": "superpowers:verification-before-completion",
        "evidence": "used",
        "enforcement": "hard"
      }
    ],
    "gate.final.request": [
      {
        "skill": "superpowers:verification-before-completion",
        "evidence": "used",
        "enforcement": "hard"
      },
      {
        "skill": "superpowers:finishing-a-development-branch",
        "evidence": "used",
        "enforcement": "hard"
      }
    ],
    "gate.final.approve": [
      {
        "skill": "superpowers:verification-before-completion",
        "evidence": "used",
        "enforcement": "hard"
      },
      {
        "skill": "superpowers:finishing-a-development-branch",
        "evidence": "used",
        "enforcement": "hard"
      }
    ],
    "action.final": [
      {
        "skill": "superpowers:verification-before-completion",
        "evidence": "used",
        "enforcement": "hard"
      },
      {
        "skill": "superpowers:finishing-a-development-branch",
        "evidence": "used",
        "enforcement": "hard"
      }
    ]
  }
}
